{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nim.agency/schema/reference/crue_type.schema.json",
  "title": "Crüe Type",
  "description": "Pre-configured agent group templates with thematic specializations",
  "@type": "skos:ConceptScheme",
  "$nim.meta": {
    "nim.id": 400025,
    "created": "2026-04-08T00:00:00Z",
    "modified": "2026-04-08T00:00:00Z",
    "version": "1.0.0",
    "layer": {
      "id": 2,
      "label": "structure",
      "component": "agency",
      "subcomponent": "reference",
      "object": "crue_type",
      "type": "schema",
      "path": "L2.agency.reference.crue_type"
    }
  },
  "type": "object",
  "properties": {
    "id": {"type": "integer"},
    "slug": {"type": "string"},
    "label": {"type": "string"},
    "description": {"type": "string"},
    "mission_profile": {"type": "string"},
    "primary_archetypes": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Core archetype slugs for this crüe"
    },
    "support_archetypes": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Optional support archetypes"
    },
    "composition": {
      "type": "object",
      "properties": {
        "min_size": {"type": "integer", "minimum": 1},
        "max_size": {"type": "integer"},
        "lead_archetype": {"type": "string"}
      }
    },
    "coordination": {
      "type": "object",
      "properties": {
        "style": {
          "type": "string",
          "enum": ["sequential", "parallel", "collaborative", "pair", "command", "broadcast"]
        },
        "handoff": {
          "type": "string",
          "enum": ["explicit", "async", "shared_context", "tight", "checkpoint", "runbook", "none"]
        },
        "escalation": {
          "type": "string",
          "enum": ["lead", "consensus", "immediate", "chain", "aggregate"]
        }
      }
    },
    "icon": {"type": "string"},
    "color": {"type": "string"},
    "sort_order": {"type": "integer"}
  },
  "required": ["id", "slug", "label", "primary_archetypes", "composition"]
}
