{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nim.agency/schema/core/credential.schema.json",
  "title": "Credential",
  "description": "Encrypted credential stored in the vault - SSH keys, passwords, tokens",
  "@type": ["schema:Credential"],
  "$ref": "https://nim.agency/schema/meta/agency.metaschema.json",
  "$nim.meta": {
    "nim.id": 400111,
    "created": "2026-04-08T00:00:00Z",
    "modified": "2026-04-08T00:00:00Z",
    "version": "1.0.0",
    "layer": {
      "id": 3,
      "label": "data",
      "component": "agency",
      "subcomponent": "core",
      "object": "credential",
      "type": "schema",
      "path": "L3.agency.core.credential"
    }
  },
  "type": "object",
  "properties": {
    "id": {
      "$ref": "https://nim.agency/schema/meta/agency.metaschema.json#/$defs/uuid",
      "description": "Unique credential identifier"
    },
    "name": {
      "type": "string",
      "maxLength": 128,
      "description": "Human-readable name for the credential"
    },
    "credential_type": {
      "type": "string",
      "enum": ["ssh_key", "password", "token", "certificate"],
      "description": "Type of credential stored"
    },
    "scope": {
      "type": "string",
      "enum": ["operator", "global"],
      "default": "operator",
      "description": "Storage scope (operator-local or system-wide)"
    },
    "metadata": {
      "type": "object",
      "description": "Additional credential metadata (NOT encrypted)",
      "properties": {
        "key_type": {
          "type": "string",
          "enum": ["rsa", "ed25519", "ecdsa", "dsa"],
          "description": "SSH key algorithm type"
        },
        "bits": {
          "type": "integer",
          "description": "Key size in bits"
        },
        "fingerprint": {
          "type": "string",
          "description": "Key fingerprint (SHA256)"
        },
        "comment": {
          "type": "string",
          "description": "Key comment from original file"
        },
        "public_key": {
          "type": "string",
          "description": "Public key (not sensitive)"
        },
        "original_path": {
          "type": "string",
          "description": "Path to original key file if imported"
        },
        "has_passphrase": {
          "type": "boolean",
          "description": "Whether key is passphrase-protected"
        },
        "expires_at": {
          "$ref": "https://nim.agency/schema/meta/agency.metaschema.json#/$defs/timestamp",
          "description": "Credential expiration time"
        }
      }
    },
    "usage": {
      "type": "object",
      "description": "Usage tracking",
      "properties": {
        "last_used": {
          "$ref": "https://nim.agency/schema/meta/agency.metaschema.json#/$defs/timestamp"
        },
        "use_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "substations": {
          "type": "array",
          "items": {"$ref": "https://nim.agency/schema/meta/agency.metaschema.json#/$defs/uuid"},
          "description": "Substations using this credential"
        }
      }
    },
    "audit": {
      "$ref": "https://nim.agency/schema/meta/agency.metaschema.json#/$defs/audit_timestamps"
    }
  },
  "required": ["id", "name", "credential_type", "scope", "audit"],
  "$comment": "Note: Actual credential data (private keys, passwords) is encrypted and stored separately in the vault file system, not in this JSON record."
}
